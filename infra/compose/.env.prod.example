# ===========================================================================
# Ironflyer production environment — copy to .env.prod and fill in.
#
#   cp infra/compose/.env.prod.example infra/compose/.env.prod
#   chmod 600 infra/compose/.env.prod
#
# Load with:
#   docker compose -f infra/compose/docker-compose.prod.yml \
#       --env-file infra/compose/.env.prod up -d
# ===========================================================================

# --- Identity ---------------------------------------------------------------
ROOT_DOMAIN=ironflyer.ai
ACME_EMAIL=ops@ironflyer.ai
IRONFLYER_VERSION=v0.42.0

# --- Container image overrides (optional; defaults are GHCR public) ---------
ORCHESTRATOR_IMAGE=ghcr.io/zorba9172/ironflyer-orchestrator:v0.42.0
RUNTIME_IMAGE=ghcr.io/zorba9172/ironflyer-runtime:v0.42.0
WEB_IMAGE=ghcr.io/zorba9172/ironflyer-web:v0.42.0

# --- Postgres (shared by app, Temporal, GlitchTip) --------------------------
# Generate: openssl rand -base64 36
POSTGRES_USER=ironflyer
POSTGRES_PASSWORD=CHANGE-ME-32-CHARS-MIN
POSTGRES_DB=ironflyer

# --- Redis (shared by app db=0, glitchtip-celery db=1) ----------------------
# Generate: openssl rand -hex 32
REDIS_PASSWORD=CHANGE-ME-32-CHARS-MIN

# --- SurrealDB (knowledge graph) --------------------------------------------
# Generate: openssl rand -hex 32
SURREAL_USER=root
SURREAL_PASSWORD=CHANGE-ME

# --- MinIO (S3 artifact store; also receives WAL-G PG backups) --------------
# Generate: openssl rand -hex 12 (access key) + openssl rand -base64 36 (secret)
MINIO_ROOT_USER=ironflyer-prod
MINIO_ROOT_PASSWORD=CHANGE-ME-32-CHARS-MIN
IRONFLYER_S3_BUCKET=ironflyer-artifacts
# Snapshot/export target. Defaults to the bundled minio above. To send
# workspace snapshots to Cloudflare R2 or DigitalOcean Spaces instead,
# uncomment and fill these (minio still runs as the WAL-G backup target):
# IRONFLYER_S3_ENDPOINT=https://<region>.digitaloceanspaces.com
# IRONFLYER_S3_ACCESS_KEY=<spaces-or-r2-key>
# IRONFLYER_S3_SECRET_KEY=<spaces-or-r2-secret>
# IRONFLYER_S3_REGION=us-east-1
# IRONFLYER_S3_FORCE_PATH_STYLE=false   # R2/Spaces use virtual-host style

# --- Analytics pipeline (OPT-IN: Redpanda + ClickHouse) ---------------------
# The lean default ships WITHOUT this pipeline: the orchestrator skips the
# event publisher and dashboards read live Postgres. That frees ~20 GB RAM
# and speeds boot. Enable OLAP analytics only when event volume warrants it:
#   1. Uncomment the two broker/host lines below.
#   2. Bring the stack up with `--profile analytics`.
# REDPANDA_BROKERS=redpanda:9092
# IRONFLYER_CLICKHOUSE_HOSTS=clickhouse:9000
CLICKHOUSE_DB=ironflyer
CLICKHOUSE_USER=ironflyer
CLICKHOUSE_PASSWORD=CHANGE-ME

# --- JWT (app auth signing) -------------------------------------------------
# Generate: openssl rand -hex 32
IRONFLYER_JWT_SECRET=CHANGE-ME-64-HEX-CHARS

# --- Superuser bootstrap (one admin account, created on first boot) ---------
# The orchestrator calls auth.EnsureSuperuser at startup when both vars are
# set. It's idempotent: the account is created on first boot, then promoted
# to the `platform_operator` role and marked email-verified on every boot
# (safe to leave set permanently — no password rotation happens here).
#
# After first boot you can log in at https://app.${ROOT_DOMAIN}/login with
# these credentials and you'll see every admin/operator surface (audit
# export, ledger, profit dashboards, gate verdict overrides, etc).
#
# Pick a strong password: openssl rand -base64 32
IRONFLYER_SUPERUSER_EMAIL=admin@ironflyer.ai
IRONFLYER_SUPERUSER_PASSWORD=CHANGE-ME-STRONG-PASSPHRASE

# --- Internal metrics token (Prometheus scrape auth) ------------------------
# Generate: openssl rand -hex 32
IRONFLYER_METRICS_TOKEN=CHANGE-ME

# --- Executor: embedded | temporal ------------------------------------------
# Temporal is the prod default (the cluster is provisioned alongside).
# Switch to "embedded" only if Temporal is unhealthy.
IRONFLYER_EXECUTOR=temporal

# --- Runtime sandbox caps ---------------------------------------------------
RUNTIME_MAX_SANDBOXES=32

# --- Grafana --------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE-ME

# --- GlitchTip (error tracking) ---------------------------------------------
# Generate: openssl rand -hex 48
GLITCHTIP_SECRET_KEY=CHANGE-ME-50-CHARS-MIN
# Disable registration after the first ops user is created — see runbook.
GLITCHTIP_ENABLE_REGISTRATION=false
# Outbound email for digest / invites (Resend SMTP example):
# GLITCHTIP_EMAIL_URL=smtp+tls://resend:${RESEND_API_KEY}@smtp.resend.com:587

# --- Sentry/GlitchTip DSNs (filled in after first GlitchTip project setup) --
SENTRY_DSN_ORCHESTRATOR=
SENTRY_DSN_RUNTIME=
SENTRY_DSN_WEB=

# --- Caddy basic-auth for ops subdomains ------------------------------------
# Generate: docker run --rm caddy:2.8-alpine caddy hash-password --plaintext 'YourPwd'
CADDY_BASIC_AUTH_HASH=$2a$14$CHANGE-ME

# --- Restic offsite backup to Hetzner Storage Box ---------------------------
# Format: sftp:u123456@u123456.your-storagebox.de:/backups/ironflyer
RESTIC_REPOSITORY=sftp:u000000@u000000.your-storagebox.de:/backups/ironflyer
# Generate: openssl rand -base64 64
RESTIC_PASSWORD=CHANGE-ME-LONG-PASSPHRASE

# --- AI providers (Anthropic is the only required one) ----------------------
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
HF_API_KEY=
VERCEL_AI_GATEWAY_TOKEN=

# --- Wallet topper providers (Stripe + Paddle) ------------------------------
# wallet.Topper is an interface with two implementations; wallet.TopperRegistry
# holds both in priority order. Either provider can stand alone — leave a key
# empty to disable that leg. IRONFLYER_WALLET_PRIMARY_PROVIDER picks which
# adapter is offered as the default on /wallet/topup ("stripe" or "paddle");
# the user can switch at the UI ("Card declined? Pay with the alternative").
# Reconciler sweeps stuck `pending` rows against both providers every 5 min.

# Stripe (primary in the default config).
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_TEAM=price_
STRIPE_PRICE_ENTERPRISE=price_

# Paddle (Israeli-friendly merchant-of-record; second leg of the topper).
# API key + webhook secret created at https://vendors.paddle.com.
# PADDLE_ENV=live for production, sandbox for test.
PADDLE_API_KEY=pdl_live_
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=live
PADDLE_PRICE_PRO=
PADDLE_PRICE_TEAM=
PADDLE_PRICE_ENTERPRISE=

# Which provider /wallet/topup defaults to. Override to "paddle" when
# Paddle is the primary collector (e.g. IL users) and Stripe is the
# fallback. Either way, both stay reachable from the UI.
IRONFLYER_WALLET_PRIMARY_PROVIDER=stripe

# --- GitHub OAuth + App (login + webhook receiver) --------------------------
GITHUB_CLIENT_ID=Iv1.
GITHUB_CLIENT_SECRET=
# Multi-line PEM — wrap in single quotes and keep the newlines:
# GITHUB_APP_PRIVATE_KEY='-----BEGIN RSA PRIVATE KEY-----
# ...
# -----END RSA PRIVATE KEY-----'
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# --- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=re_
