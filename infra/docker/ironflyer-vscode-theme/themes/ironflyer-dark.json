  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#777096", "fontStyle": "italic" }
    },
    {
      "scope": ["constant", "constant.numeric", "constant.language", "support.constant"],
      "settings": { "foreground": "#7fe28a" }
    },
    {
      "scope": ["string", "string.quoted", "punctuation.definition.string"],
      "settings": { "foreground": "#ff7848" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#e149c9" }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#ffb457" }
    },
    {
      "scope": ["keyword", "keyword.control", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#b56cff", "fontStyle": "" }
    },
    {
      "scope": ["keyword.operator", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#b9b2d3" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#7eb7ff" }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"],
      "settings": { "foreground": "#e149c9" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#b56cff" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#ffb457", "fontStyle": "" }
    },
    {
      "scope": ["variable", "variable.parameter", "variable.other"],
      "settings": { "foreground": "#f7f4ff" }
    },
    {
      "scope": ["variable.language", "variable.language.self", "variable.language.this"],
      "settings": { "foreground": "#ff7848", "fontStyle": "italic" }
    },
    {
      "scope": ["meta.object-literal.key", "support.type.property-name"],
      "settings": { "foreground": "#8fc7ff" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ff4f6d" }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#ffb457", "fontStyle": "strikethrough" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#f7f4ff", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#b9b2d3", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#b56cff", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#7fe28a" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ff4f6d" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#ffb457" }
    },
    {
      "scope": ["markup.quote"],
      "settings": { "foreground": "#b9b2d3", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.link", "string.other.link"],
      "settings": { "foreground": "#7eb7ff", "fontStyle": "underline" }
    }
  ]
}
