      "editorBracketMatch.border": "#7dd3fc",
      "editorCursor.foreground": "#ef6f5e",
      "editorGroup.border": "#101624",
      "editorGroupHeader.tabsBackground": "#05070d",
      "editorGutter.background": "#05070d",
      "editorIndentGuide.activeBackground1": "#7dd3fc66",
      "editorIndentGuide.background1": "#47556933",
      "editorLineNumber.activeForeground": "#7dd3fc",
      "editorLineNumber.foreground": "#64748b",
      "focusBorder": "#7dd3fc",
      "input.background": "#101624",
      "input.border": "#263244",
      "input.foreground": "#f8fafc",
      "list.activeSelectionBackground": "#143047",
      "list.activeSelectionForeground": "#f8fafc",
      "list.hoverBackground": "#101624",
      "list.inactiveSelectionBackground": "#0b1020",
      "notifications.background": "#101624",
      "notifications.foreground": "#f8fafc",
      "panel.background": "#080b13",
