      "terminal.foreground": "#f8fafc",
      "terminalCursor.foreground": "#ef6f5e",
      "textLink.activeForeground": "#ef6f5e",
      "textLink.foreground": "#7dd3fc",
      "titleBar.activeBackground": "#05070d",
      "titleBar.activeForeground": "#f8fafc",
      "titleBar.inactiveBackground": "#05070d"
