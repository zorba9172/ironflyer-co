  "breadcrumbs.enabled": false,
  "debug.console.fontFamily": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
  "debug.toolBarLocation": "docked",
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeLens": false,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.detectIndentation": true,
  "editor.dragAndDrop": false,
  "editor.fontFamily": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.formatOnSave": true,
  "editor.glyphMargin": false,
  "editor.guides.bracketPairs": "active",
  "editor.hover.delay": 650,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.lightbulb.enabled": "off",
  "editor.lineDecorationsWidth": 8,
  "editor.lineHeight": 20,
  "editor.matchBrackets": "always",
  "editor.minimap.enabled": false,
  "editor.quickSuggestionsDelay": 120,
  "editor.renderFinalNewline": "on",
  "editor.renderLineHighlight": "line",
  "editor.renderLineHighlightOnlyWhenFocus": true,
  "editor.renderWhitespace": "selection",
  "editor.scrollBeyondLastLine": false,
  "editor.showFoldingControls": "mouseover",
  "editor.smoothScrolling": true,
  "editor.snippetSuggestions": "inline",
  "editor.stickyScroll.enabled": false,
  "editor.suggest.preview": true,
  "editor.wordWrap": "off",
  "explorer.compactFolders": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, pnpm-lock.yaml, yarn.lock, bun.lockb",
    "tsconfig.json": "tsconfig.*.json",
    "*.ts": "$(capture).test.ts, $(capture).spec.ts",
    "*.tsx": "$(capture).test.tsx, $(capture).spec.tsx"
  },
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "extensions.ignoreRecommendations": true,
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true
  },
  "git.autofetch": false,
  "git.confirmSync": false,
  "git.decorations.enabled": false,
  "git.openRepositoryInParentFolders": "never",
  "git.showPushSuccessNotification": false,
  "gitlens.showWhatsNewAfterUpgrades": false,
  "problems.decorations.enabled": false,
  "redhat.telemetry.enabled": false,
  "scm.diffDecorations": "overview",
  "search.exclude": {
    "**/.git": true,
    "**/.next": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "search.followSymlinks": false,
  "security.workspace.trust.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.fontFamily": "ui-monospace, 'SF Mono', Menlo, monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.minimumContrastRatio": 1,
  "terminal.integrated.tabs.enabled": false,
  "update.mode": "none",
  "window.commandCenter": true,
  "window.density.editorTabHeight": "compact",
  "window.density.statusBarHeight": "compact",
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "compact",
  "window.restoreWindows": "none",
  "window.title": "IronFlyer · ${rootName}${separator}${activeEditorShort}",
  "workbench.activityBar.location": "hidden",
  "workbench.editor.editorActionsLocation": "hidden",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.labelFormat": "short",
  "workbench.editor.showIcons": false,
  "workbench.editor.pinnedTabsOnSeparateRow": false,
  "workbench.editor.showTabs": "single",
  "workbench.editor.tabSizing": "shrink",
  "workbench.layoutControl.enabled": false,
  "workbench.list.smoothScrolling": true,
  "workbench.panel.defaultLocation": "bottom",
  "workbench.panel.opensMaximized": "never",
  "workbench.productIconTheme": "Default",
  "workbench.settings.editor": "json",
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.welcomePage.walkthroughs.openOnInstall": false
}
