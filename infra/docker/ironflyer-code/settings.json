      "checkbox.background": "#101624",
      "checkbox.border": "#263244",
      "commandCenter.background": "#05070d",
      "commandCenter.border": "#263244",
      "commandCenter.foreground": "#dbeafe",
      "diffEditor.insertedTextBackground": "#134e4a55",
      "diffEditor.removedTextBackground": "#7f1d1d55",
      "dropdown.background": "#101624",
