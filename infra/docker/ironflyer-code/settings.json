      "sideBarSectionHeader.foreground": "#f8fafc",
      "sideBarTitle.foreground": "#f8fafc",
      "statusBar.background": "#05070d",
      "statusBar.foreground": "#cbd5e1",
      "statusBar.noFolderBackground": "#05070d",
      "statusBarItem.remoteBackground": "#2563eb",
      "statusBarItem.remoteForeground": "#f8fafc",
      "tab.activeBackground": "#0b1020",
      "tab.activeBorderTop": "#7dd3fc",
