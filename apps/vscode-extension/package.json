{
  "name": "ironflyer",
  "displayName": "Ironflyer — AI Product Finisher",
  "description": "Finish products end-to-end inside VSCode. Chat with the agent, watch Finisher gates pass or fail, review patches in a native diff, run a live preview of your project, and track budget — all without leaving your editor.",
  "publisher": "ironflyer",
  "version": "0.3.0",
  "license": "Apache-2.0",
  "homepage": "https://ironflyer.dev",
  "bugs": {
    "url": "https://github.com/zorba9172/ironflyer/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zorba9172/ironflyer"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0E0F12",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ironflyer",
    "ai",
    "agents",
    "lovable",
    "copilot",
    "finisher",
    "gates",
    "preview",
    "lovable.dev",
    "base44"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Ironflyer",
      "properties": {
        "ironflyer.orchestratorUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL of the Ironflyer orchestrator. Set to https://api.ironflyer.dev for production."
        },
        "ironflyer.apiUrl": {
          "type": "string",
          "default": "",
          "description": "Alias for orchestratorUrl. When set, overrides ironflyer.orchestratorUrl."
        },
        "ironflyer.runtimeUrl": {
          "type": "string",
          "default": "http://localhost:8090",
          "description": "Base URL of the Ironflyer workspace runtime. Used by the Live Preview to fetch the per-project preview iframe URL."
        },
        "ironflyer.webUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL of the Ironflyer web app — used for the sign-in handshake."
        },
        "ironflyer.defaultProject": {
          "type": "string",
          "default": "",
          "description": "Project ID to pin automatically on first activation in a new window. Leave empty to be prompted."
        },
        "ironflyer.sentryDsn": {
          "type": "string",
          "default": "",
          "description": "Optional Sentry DSN. When set, the extension reports unhandled errors to Sentry. Leave empty to disable error telemetry entirely (default — no data leaves your editor)."
        },
        "ironflyer.preview.defaultViewport": {
          "type": "string",
          "enum": [
            "responsive",
            "mobile",
            "tablet",
            "desktop"
          ],
          "default": "responsive",
          "description": "Initial viewport size for the Live Preview pane."
        },
        "ironflyer.completions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Cursor-style inline AI completions as ghost text while you type. Toggle from the status bar pill or via the 'Ironflyer: Toggle Inline AI' command."
        },
        "ironflyer.completions.debounceMs": {
          "type": "number",
          "default": 250,
          "minimum": 50,
          "maximum": 2000,
          "description": "Milliseconds to wait after the cursor settles before requesting an inline completion."
        },
        "ironflyer.completions.maxLines": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 40,
          "description": "Maximum number of lines to display in an inline AI suggestion. Lower values keep suggestions snappy and visually quiet."
        }
      }
    },
    "commands": [
      {
        "command": "ironflyer.signIn",
        "title": "Ironflyer: Sign In"
      },
      {
        "command": "ironflyer.signOut",
        "title": "Ironflyer: Sign Out"
      },
      {
        "command": "ironflyer.refresh",
        "title": "Ironflyer: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ironflyer.openChat",
        "title": "Ironflyer: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "ironflyer.newProject",
        "title": "Ironflyer: New Project",
        "icon": "$(add)"
      },
      {
        "command": "ironflyer.runFinisher",
        "title": "Ironflyer: Run Finisher",
        "icon": "$(play)"
      },
      {
        "command": "ironflyer.rerunGate",
        "title": "Ironflyer: Re-run this Gate",
        "icon": "$(debug-restart)"
      },
      {
        "command": "ironflyer.openPreview",
        "title": "Ironflyer: Open Live Preview",
        "icon": "$(preview)"
      },
      {
        "command": "ironflyer.refreshPreview",
        "title": "Ironflyer: Refresh Preview",
        "icon": "$(refresh)"
      },
      {
        "command": "ironflyer.openPreviewInBrowser",
        "title": "Ironflyer: Open Preview in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "ironflyer.openProjectInBrowser",
        "title": "Ironflyer: Open Project in Browser"
      },
      {
        "command": "ironflyer.showBudget",
        "title": "Ironflyer: Show Budget"
      },
      {
        "command": "ironflyer.showPatchDiff",
        "title": "Ironflyer: Show Patch Diff"
      },
      {
        "command": "ironflyer.applyPatch",
        "title": "Ironflyer: Apply Patch",
        "icon": "$(check)"
      },
      {
        "command": "ironflyer.rejectPatch",
        "title": "Ironflyer: Reject Patch",
        "icon": "$(close)"
      },
      {
        "command": "ironflyer.setActiveProject",
        "title": "Ironflyer: Set Active Project"
      },
      {
        "command": "ironflyer.fixDiagnostic",
        "title": "Ironflyer: Ask Ironflyer to Fix"
      },
      {
        "command": "ironflyer.showLogs",
        "title": "Ironflyer: Show Logs"
      },
      {
        "command": "ironflyer.showRunOutput",
        "title": "Ironflyer: Show Run Output"
      },
      {
        "command": "ironflyer.quickActions",
        "title": "Ironflyer: Quick Actions",
        "icon": "$(zap)"
      },
      {
        "command": "ironflyer.openDependencyGraph",
        "title": "Ironflyer: Open Dependency Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "ironflyer.openMemoryRecord",
        "title": "Ironflyer: Open Memory Record"
      },
      {
        "command": "ironflyer.toggleInlineCompletions",
        "title": "Ironflyer: Toggle Inline AI"
      },
      {
        "command": "ironflyer.inlineCompletionAccepted",
        "title": "Ironflyer: Inline Completion Accepted (telemetry)"
      }
    ],
    "keybindings": [
      {
        "command": "ironflyer.openChat",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "ironflyer.signedIn"
      },
      {
        "command": "ironflyer.newProject",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "ironflyer.signedIn"
      },
      {
        "command": "ironflyer.openPreview",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "ironflyer.signedIn"
      },
      {
        "command": "ironflyer.runFinisher",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "ironflyer.signedIn && ironflyer.hasActiveProject"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ironflyer",
          "title": "Ironflyer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ironflyer": [
        {
          "id": "ironflyer.projects",
          "name": "Projects",
          "icon": "$(rocket)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.patches",
          "name": "Patches",
          "icon": "$(git-pull-request)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.gates",
          "name": "Finisher Gates",
          "icon": "$(checklist)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.memory",
          "name": "Memory",
          "icon": "$(book)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.audit",
          "name": "Audit",
          "icon": "$(shield)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.telemetry",
          "name": "Agent Telemetry",
          "icon": "$(pulse)",
          "contextualTitle": "Ironflyer"
        },
        {
          "type": "webview",
          "id": "ironflyer.preview",
          "name": "Live Preview",
          "icon": "$(preview)",
          "contextualTitle": "Ironflyer"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "ironflyer.gettingStarted",
        "title": "Get started with Ironflyer",
        "description": "Sign in, pin a project, and finish products without leaving your editor.",
        "steps": [
          {
            "id": "signIn",
            "title": "Sign in",
            "description": "Open the Ironflyer web app in your browser and bounce the JWT back to VSCode. No API keys to paste.\n[Sign In](command:ironflyer.signIn)",
            "media": {
              "markdown": "media/walkthrough/sign-in.md"
            },
            "completionEvents": [
              "onContext:ironflyer.signedIn"
            ]
          },
          {
            "id": "pinProject",
            "title": "Pin a project",
            "description": "Tell Ironflyer which project this window belongs to. The pin powers the Ask Ironflyer to Fix quick action and is persisted per workspace.\n[Set Active Project](command:ironflyer.setActiveProject)",
            "media": {
              "markdown": "media/walkthrough/pin-project.md"
            },
            "completionEvents": [
              "onContext:ironflyer.hasActiveProject"
            ]
          },
          {
            "id": "openChat",
            "title": "Open chat for a project",
            "description": "Open the streaming chat panel and try a prompt. The agent role + effort dial mirror the web app.\n[Open Chat](command:ironflyer.openChat)",
            "media": {
              "markdown": "media/walkthrough/open-chat.md"
            },
            "completionEvents": [
              "onCommand:ironflyer.openChat"
            ]
          },
          {
            "id": "openPreview",
            "title": "See your project live",
            "description": "Open the Live Preview pane to see your sandboxed workspace render in real time.\n[Open Live Preview](command:ironflyer.openPreview)"
          },
          {
            "id": "askToFix",
            "title": "Ask Ironflyer to fix a diagnostic",
            "description": "Hover any TypeScript / ESLint / Go diagnostic, press the lightbulb, and pick \"Ask Ironflyer to fix\". The extension bundles the snippet + message + range and routes it to the coder agent.",
            "media": {
              "markdown": "media/walkthrough/ask-to-fix.md"
            }
          },
          {
            "id": "reviewPatches",
            "title": "Review and apply patches",
            "description": "Every patch the orchestrator proposes shows up in the Patches view. Click a file to open a native side-by-side diff; tap the checkmark to apply.\n[Open Patches](command:workbench.view.extension.ironflyer)",
            "media": {
              "markdown": "media/walkthrough/patches.md"
            }
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "ironflyer.projects",
        "contents": "Sign in to Ironflyer to see your projects.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.projects",
        "contents": "No projects yet — start your first one.\n[New Project](command:ironflyer.newProject)",
        "when": "ironflyer.signedIn"
      },
      {
        "view": "ironflyer.patches",
        "contents": "Sign in to Ironflyer to review patches.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.patches",
        "contents": "No proposed patches yet. Patches show up here once an agent proposes a change.",
        "when": "ironflyer.signedIn"
      },
      {
        "view": "ironflyer.gates",
        "contents": "Sign in to Ironflyer to see Finisher gates.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.memory",
        "contents": "Sign in to Ironflyer to browse project memory.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.audit",
        "contents": "Sign in to Ironflyer to view the audit log.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.telemetry",
        "contents": "Sign in to Ironflyer to see agent telemetry.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ironflyer.newProject",
          "when": "view == ironflyer.projects",
          "group": "navigation@1"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.projects",
          "group": "navigation@2"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.patches",
          "group": "navigation"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.gates",
          "group": "navigation"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.memory",
          "group": "navigation"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.audit",
          "group": "navigation"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.telemetry",
          "group": "navigation"
        },
        {
          "command": "ironflyer.openDependencyGraph",
          "when": "view == ironflyer.projects",
          "group": "navigation@3"
        },
        {
          "command": "ironflyer.refreshPreview",
          "when": "view == ironflyer.preview",
          "group": "navigation@1"
        },
        {
          "command": "ironflyer.openPreviewInBrowser",
          "when": "view == ironflyer.preview",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "ironflyer.fixDiagnostic",
          "when": "false"
        },
        {
          "command": "ironflyer.rerunGate",
          "when": "false"
        },
        {
          "command": "ironflyer.showPatchDiff",
          "when": "false"
        },
        {
          "command": "ironflyer.openMemoryRecord",
          "when": "false"
        },
        {
          "command": "ironflyer.inlineCompletionAccepted",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "ironflyer.openChat",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project",
          "group": "inline"
        },
        {
          "command": "ironflyer.openPreview",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project",
          "group": "inline"
        },
        {
          "command": "ironflyer.openProjectInBrowser",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project"
        },
        {
          "command": "ironflyer.runFinisher",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project"
        },
        {
          "command": "ironflyer.applyPatch",
          "when": "view == ironflyer.patches && (viewItem == ironflyer.patch.validated || viewItem == ironflyer.patch.proposed)",
          "group": "inline"
        },
        {
          "command": "ironflyer.rejectPatch",
          "when": "view == ironflyer.patches && (viewItem == ironflyer.patch.validated || viewItem == ironflyer.patch.proposed)",
          "group": "1_modify"
        },
        {
          "command": "ironflyer.runFinisher",
          "when": "view == ironflyer.gates && viewItem == ironflyer.gateProject",
          "group": "inline"
        },
        {
          "command": "ironflyer.rerunGate",
          "when": "view == ironflyer.gates && viewItem =~ /^ironflyer\\.gate\\./",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "graphql-codegen --config codegen.yml",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "ovsx": "^0.9.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@sentry/node": "^10.53.1",
    "graphql": "^16.14.0",
    "graphql-ws": "^5.16.2",
    "ws": "^8.21.0"
  }
}
