{
  "name": "ironflyer",
  "displayName": "Ironflyer",
  "description": "Finish products end-to-end with Ironflyer — chat, Finisher gates, budget, and project actions, right inside VSCode.",
  "publisher": "ironflyer",
  "version": "0.2.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zorba9172/ironflyer"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ironflyer",
    "ai",
    "agents",
    "lovable",
    "copilot"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Ironflyer",
      "properties": {
        "ironflyer.orchestratorUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL of the Ironflyer orchestrator. Set to https://api.ironflyer.dev for production."
        },
        "ironflyer.webUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL of the Ironflyer web app — used for the sign-in handshake."
        }
      }
    },
    "commands": [
      {
        "command": "ironflyer.signIn",
        "title": "Ironflyer: Sign In"
      },
      {
        "command": "ironflyer.signOut",
        "title": "Ironflyer: Sign Out"
      },
      {
        "command": "ironflyer.refresh",
        "title": "Ironflyer: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "ironflyer.openChat",
        "title": "Ironflyer: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "ironflyer.newProject",
        "title": "Ironflyer: New Project",
        "icon": "$(add)"
      },
      {
        "command": "ironflyer.runFinisher",
        "title": "Ironflyer: Run Finisher"
      },
      {
        "command": "ironflyer.openProjectInBrowser",
        "title": "Ironflyer: Open Project in Browser"
      },
      {
        "command": "ironflyer.showBudget",
        "title": "Ironflyer: Show Budget"
      },
      {
        "command": "ironflyer.showPatchDiff",
        "title": "Ironflyer: Show Patch Diff"
      },
      {
        "command": "ironflyer.applyPatch",
        "title": "Ironflyer: Apply Patch",
        "icon": "$(check)"
      },
      {
        "command": "ironflyer.setActiveProject",
        "title": "Ironflyer: Set Active Project"
      },
      {
        "command": "ironflyer.fixDiagnostic",
        "title": "Ironflyer: Ask Ironflyer to Fix"
      },
      {
        "command": "ironflyer.showLogs",
        "title": "Ironflyer: Show Logs"
      }
    ],
    "keybindings": [
      { "command": "ironflyer.openChat", "key": "ctrl+alt+i", "mac": "cmd+alt+i", "when": "ironflyer.signedIn" },
      { "command": "ironflyer.newProject", "key": "ctrl+alt+n", "mac": "cmd+alt+n", "when": "ironflyer.signedIn" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ironflyer",
          "title": "Ironflyer",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ironflyer": [
        {
          "id": "ironflyer.projects",
          "name": "Projects",
          "icon": "$(rocket)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.patches",
          "name": "Patches",
          "icon": "$(git-pull-request)",
          "contextualTitle": "Ironflyer"
        },
        {
          "id": "ironflyer.gates",
          "name": "Finisher Gates",
          "icon": "$(checklist)",
          "contextualTitle": "Ironflyer"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "ironflyer.gettingStarted",
        "title": "Get started with Ironflyer",
        "description": "Sign in, pin a project, and finish products without leaving your editor.",
        "steps": [
          {
            "id": "signIn",
            "title": "Sign in",
            "description": "Open the Ironflyer web app in your browser and bounce the JWT back to VSCode. No API keys to paste.\n[Sign In](command:ironflyer.signIn)",
            "media": { "markdown": "media/walkthrough/sign-in.md" },
            "completionEvents": ["onContext:ironflyer.signedIn"]
          },
          {
            "id": "pinProject",
            "title": "Pin a project",
            "description": "Tell Ironflyer which project this window belongs to. The pin powers the Ask Ironflyer to Fix quick action and is persisted per workspace.\n[Set Active Project](command:ironflyer.setActiveProject)",
            "media": { "markdown": "media/walkthrough/pin-project.md" },
            "completionEvents": ["onContext:ironflyer.hasActiveProject"]
          },
          {
            "id": "openChat",
            "title": "Open chat for a project",
            "description": "Open the streaming chat panel and try a prompt. The agent role + effort dial mirror the web app.\n[Open Chat](command:ironflyer.openChat)",
            "media": { "markdown": "media/walkthrough/open-chat.md" },
            "completionEvents": ["onCommand:ironflyer.openChat"]
          },
          {
            "id": "askToFix",
            "title": "Ask Ironflyer to fix a diagnostic",
            "description": "Hover any TypeScript / ESLint / Go diagnostic, press the lightbulb, and pick \"Ask Ironflyer to fix\". The extension bundles the snippet + message + range and routes it to the coder agent.",
            "media": { "markdown": "media/walkthrough/ask-to-fix.md" }
          },
          {
            "id": "reviewPatches",
            "title": "Review and apply patches",
            "description": "Every patch the orchestrator proposes shows up in the Patches view. Click a file to open a native side-by-side diff; tap ✔ to apply.\n[Open Patches](command:workbench.view.extension.ironflyer)",
            "media": { "markdown": "media/walkthrough/patches.md" }
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "ironflyer.projects",
        "contents": "Sign in to Ironflyer to see your projects.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.projects",
        "contents": "No projects yet — start your first one.\n[New Project](command:ironflyer.newProject)",
        "when": "ironflyer.signedIn"
      },
      {
        "view": "ironflyer.patches",
        "contents": "Sign in to Ironflyer to review patches.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      },
      {
        "view": "ironflyer.patches",
        "contents": "No proposed patches yet. Patches show up here once an agent proposes a change.",
        "when": "ironflyer.signedIn"
      },
      {
        "view": "ironflyer.gates",
        "contents": "Sign in to Ironflyer to see Finisher gates.\n[Sign In](command:ironflyer.signIn)",
        "when": "!ironflyer.signedIn"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ironflyer.newProject",
          "when": "view == ironflyer.projects",
          "group": "navigation@1"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.projects",
          "group": "navigation@2"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.patches",
          "group": "navigation"
        },
        {
          "command": "ironflyer.refresh",
          "when": "view == ironflyer.gates",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "ironflyer.fixDiagnostic",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "ironflyer.openChat",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project",
          "group": "inline"
        },
        {
          "command": "ironflyer.openProjectInBrowser",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project"
        },
        {
          "command": "ironflyer.runFinisher",
          "when": "view == ironflyer.projects && viewItem == ironflyer.project"
        },
        {
          "command": "ironflyer.applyPatch",
          "when": "view == ironflyer.patches && (viewItem == ironflyer.patch.validated || viewItem == ironflyer.patch.proposed)",
          "group": "inline"
        },
        {
          "command": "ironflyer.runFinisher",
          "when": "view == ironflyer.gates && viewItem == ironflyer.gateProject",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "ovsx": "^0.9.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
