{
  "expo": {
    "name": "Ironflyer Expo App",
    "slug": "ironflyer-expo-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ironflyerexpo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0a0a0a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ironflyer.expoapp"
    },
    "android": {
      "package": "com.ironflyer.expoapp",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
