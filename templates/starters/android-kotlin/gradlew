#!/usr/bin/env sh
#
# Minimal Gradle wrapper bootstrap.
#
# The full wrapper (gradle-wrapper.jar + scripts) is intentionally not
# committed here. To materialise it, run on any host with Gradle installed:
#
#   gradle wrapper --gradle-version 8.11.1
#
# Android Studio will also offer to regenerate the wrapper when the project
# is opened for the first time.

echo "gradlew is not initialised yet."
echo "Run \`gradle wrapper --gradle-version 8.11.1\` from a host with Gradle installed,"
echo "or open this project in Android Studio so it can regenerate the wrapper."
exit 1
