# Ironflyer iOS starter — fastlane lanes.
#
# `bundle exec fastlane simulator` rebuilds the Debug binary for the
# generic iOS Simulator destination — the cheapest possible
# verification that the project compiles. `bundle exec fastlane beta`
# is the TestFlight pipeline; it fetches signing material via match,
# bumps the build number, archives a Release build, and uploads to
# App Store Connect.

default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV['CI']
  end

  desc "Build the app for the iOS Simulator"
  lane :simulator do
    sh "make generate"
    xcodebuild(
      project: "../IronflyerStarter.xcodeproj",
      scheme: "IronflyerStarter",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
    )
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    sh "make generate"
    match(type: "appstore", readonly: true)
    increment_build_number(xcodeproj: "../IronflyerStarter.xcodeproj")
    build_app(
      project: "../IronflyerStarter.xcodeproj",
      scheme: "IronflyerStarter",
    )
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end
