{
  "expo": {
    "name": "Ironflyer Starter",
    "slug": "ironflyer-starter",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ironflyerstarter",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050507"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ironflyer.starter"
    },
    "android": {
      "package": "com.ironflyer.starter",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050507"
      },
      "permissions": ["INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
