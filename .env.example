# =============================================================================
# Ironflyer — environment variables
#
# Copy this file to .env.local (gitignored) and fill in the values you need.
# Anything left blank disables the feature it gates — the orchestrator logs a
# warning at boot and continues with the no-op path.
#
# Legend in comments:
#   [REQUIRED]    — without this the orchestrator runs only on `mock` provider
#                    OR a critical surface returns 503
#   [RECOMMENDED] — strongly suggested for any non-trivial deployment
#   [OPTIONAL]    — only set when you opt into the feature
#
# V22 economic laws this file ENFORCES:
#   1. No execution starts without a wallet hold (Stripe + wallet).
#   2. No expensive call runs without ProfitGuard ROI check.
#   3. No scale is healthy unless gross margin stays protected.
# =============================================================================


# =============================================================================
# 0. CORE SECURITY (orchestrator + runtime share these)
# =============================================================================

# [REQUIRED] HS256 signing key for all session JWTs. Must be ≥ 32 chars in
# prod. The runtime also reads it to verify tokens minted by orchestrator.
IRONFLYER_JWT_SECRET=dev-secret-change-me

# Issuer claim baked into every JWT.
IRONFLYER_JWT_ISSUER=ironflyer

# [REQUIRED-PROD] HMAC secret the runtime uses to sign sandbox-preview URL
# tokens. Treat as a separate secret from the JWT one.
IRONFLYER_RUNTIME_PREVIEW_TOKEN_SECRET=
IRONFLYER_RUNTIME_PREVIEW_TOKEN_TTL=30m

# [RECOMMENDED] HMAC for signing audit-export bundles. Must be ≥ 32 bytes.
IRONFLYER_AUDIT_EXPORT_HMAC_SECRET=

# When true, unauthenticated routes are allowed for happy-path demos. Never
# enable in prod.
IRONFLYER_AUTH_OPTIONAL=false

# ---- Superuser bootstrap (privileged backdoor) ------------------------------
# WARNING: when both are set, main.go idempotently provisions a
# platform_operator account with this email + password and a verified email.
# This is an ops/debug escape hatch — rotate immediately after use, never
# commit real values, and prefer the GraphQL admin role-grant flow for
# day-to-day operator onboarding.
IRONFLYER_SUPERUSER_EMAIL=
IRONFLYER_SUPERUSER_PASSWORD=


# =============================================================================
# 1. ORCHESTRATOR — HTTP + runtime
# =============================================================================

IRONFLYER_ADDR=:8080
IRONFLYER_ENV=dev                  # dev | staging | prod
IRONFLYER_LOG_LEVEL=info           # debug | info | warn | error
IRONFLYER_LOG_FORMAT=console       # console | json

# CORS allowlist for the SPA. Comma-separated. Empty = reflect any origin (dev
# convenience only). Production MUST set this to the exact web origin(s).
IRONFLYER_CORS_ORIGINS=

# Executor: embedded runs the finisher in-process (default). temporal hands
# it to a Temporal workflow worker (production scale).
IRONFLYER_EXECUTOR=embedded        # embedded | temporal
TEMPORAL_ADDR=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ironflyer-finisher
# Opt-in switch — when set, main.go boots a worker on startup.
IRONFLYER_TEMPORAL_HOST=

# Workspace runtime URL (core/runtime). The orchestrator proxies clone / file
# / PTY traffic through here.
IRONFLYER_RUNTIME_URL=http://localhost:8090

# Public web origin. Used to render deep-link URLs in transactional surfaces.
IRONFLYER_PUBLIC_BASE_URL=http://localhost:3000


# =============================================================================
# 2. AI PROVIDERS (generative models)
#
# At least ONE provider key is required, otherwise the router falls back to
# the `mock` provider and every execution returns lorem-ipsum text. The bandit
# learns per-tenant which provider wins on reward (gate pass + cost).
# =============================================================================

# ---- Anthropic (default / Claude 4.x family) --------------------------------
# [REQUIRED for prod] The provider promotes to Opus 4.7 for
# quality/thinking/reasoning, demotes to Haiku 4.5 for cheap/fast/inline.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- OpenAI (gpt-4o / gpt-4o-mini / o3) -------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Google Gemini (gemini-2.5-pro / gemini-2.5-flash) ----------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# ---- DeepSeek (OpenAI-compatible, optional zero-egress fallback) ------------
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_GENERAL_MODEL=deepseek-chat
DEEPSEEK_REASONING_MODEL=deepseek-reasoner
DEEPSEEK_CODER_MODEL=deepseek-coder
DEEPSEEK_PREFER_V3_FOR_CODE=false
# Operator hard-kill (independent of API key) — false to opt out for
# compliance (DeepSeek is a Chinese provider).
IRONFLYER_DEEPSEEK_ENABLED=true

# ---- Vercel AI Gateway (OpenAI-compatible proxy across multiple vendors) ----
VERCEL_AI_GATEWAY_TOKEN=
VERCEL_AI_GATEWAY_URL=https://gateway.ai.vercel.com/v1
VERCEL_AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-6

# ---- Bandit (which provider does the router try first?) ---------------------
IRONFLYER_BANDIT_STRATEGY=epsilon-greedy    # epsilon-greedy | thompson | round-robin


# =============================================================================
# 3. EMBEDDINGS + MEMORY (semantic re-rank for the memory store)
# =============================================================================

# HuggingFace Inference — powers the BAAI/bge-m3 embedder. Leave blank to
# fall back to substring search (memory still works, just less smart).
HF_API_KEY=
HF_EMBED_MODEL=BAAI/bge-m3
HF_EMBEDDINGS_MODEL=

# Embeddings driver. "hf" needs HF_API_KEY; "onnx" needs the ONNX_* paths
# below and a binary built with `-tags onnx`. "auto" tries ONNX, falls back
# to HF.
IRONFLYER_EMBEDDINGS_BACKEND=hf    # hf | onnx | auto

# ONNX local embedder — only used when EmbeddingsBackend=onnx (or =auto).
IRONFLYER_ONNX_MODEL=
IRONFLYER_ONNX_VOCAB=
IRONFLYER_ONNX_DIM=0


# =============================================================================
# 4. AI TOOLS (model-callable tools wired into the Coder)
# =============================================================================

# DALL·E image generation tool. If blank, falls back to OPENAI_API_KEY. If
# both blank, the tool is registered but every call returns "disabled".
OPENAI_IMAGE_API_KEY=

# Figma import (figma_import tool + /api/projects/:id/figma-import).
FIGMA_TOKEN=

# Context7 — public MCP server that ships fresh library docs. Enabled by
# default; the token only raises the rate limit.
IRONFLYER_CONTEXT7_ENABLED=true
IRONFLYER_CONTEXT7_TOKEN=

# Outbound MCP clients. Comma-separated `name=URL` pairs. For each `name`
# add a corresponding `IRONFLYER_MCP_TOKEN_<UPPERCASE_NAME>` bearer below.
# Example:
#   IRONFLYER_MCP_SERVERS=notion=https://mcp.notion.com,linear=https://mcp.linear.app
#   IRONFLYER_MCP_TOKEN_NOTION=secret_xxx
#   IRONFLYER_MCP_TOKEN_LINEAR=lin_xxx
IRONFLYER_MCP_SERVERS=


# =============================================================================
# 5. PAYMENTS (Stripe — wallet top-up + metered overage)
#
# Without STRIPE_SECRET_KEY: /budget/checkout and /budget/webhook return 503,
# the wallet can only be loaded by an admin script. Blocking for prod.
# =============================================================================

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Plan-tier price IDs. Users buy a tier, not a specific price.
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=

# Metered (usage_type=metered) overage prices above each tier's cost cap.
STRIPE_METERED_PRICE_PRO=
STRIPE_METERED_PRICE_TEAM=

# Global kill-switch for the metered reporter (true = keep wired but don't
# flush — useful for staging or Stripe-outage incident response).
IRONFLYER_METERED_DISABLED=false
IRONFLYER_METERED_FLUSH_INTERVAL=60s

STRIPE_SUCCESS_URL=http://localhost:3000/app/settings?stripe=success
STRIPE_CANCEL_URL=http://localhost:3000/pricing?stripe=cancel

# ---- Paddle (alternative payment provider) ----------------------------------
# Coexists with Stripe — the user picks at checkout. Without PADDLE_API_KEY
# the /budget/paddle/webhook route returns 503 and the registry skips it.
# PADDLE_ENV switches the API base between live and sandbox.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=live                    # live | sandbox

# Plan-tier Paddle price IDs (pri_...). Users buy a tier, not a specific price.
PADDLE_PRICE_PRO=
PADDLE_PRICE_TEAM=
PADDLE_PRICE_ENTERPRISE=


# =============================================================================
# 6. GITHUB INTEGRATION
# =============================================================================

# ---- GitHub OAuth (login button) --------------------------------------------
# Unprefixed names are accepted as-is; IRONFLYER_-prefixed variants are not.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback
GITHUB_POST_LOGIN_URL=http://localhost:3000/app

# ---- OAuth state HMAC secret (shared by Google + GitHub) --------------------
# Generate via: openssl rand -hex 32
# Required in prod when any OAuth provider has a CLIENT_ID set.
IRONFLYER_OAUTH_STATE_SECRET=

# ---- Google OAuth (login button) --------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/auth/google/callback (dev)
# In prod: https://api.ironflyer.dev/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
GOOGLE_POST_LOGIN_URL=http://localhost:3000/app

# ---- GitHub App (PR reviews, webhooks, commit statuses) ---------------------
# PRIVATE_KEY can be a literal PEM (newlines OK) or `@/path/to/key.pem`.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=


# =============================================================================
# 7. DEPLOY ADAPTERS (Vercel — preview + promote)
#
# VERCEL_TOKEN is resolved per-tenant by SecretResolver (deploy/vercel.go) at
# call time, NOT as a global env. Set it here only if you want a global
# fallback token; otherwise inject per-tenant via the secrets store.
# =============================================================================

# VERCEL_TOKEN=


# =============================================================================
# 8. STORAGE — S3-compatible object store
#
# S3_BACKEND picks the driver. Each driver reads its own KEY_ID / SECRET pair.
# =============================================================================

S3_BACKEND=                        # aws | r2 | minio | do (DigitalOcean Spaces)

# ---- AWS S3 -----------------------------------------------------------------
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Cloudflare R2 (zero-egress) --------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ---- DigitalOcean Spaces ----------------------------------------------------
DO_SPACES_REGION=
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=

# ---- MinIO self-hosted ------------------------------------------------------
MINIO_ENDPOINT=
MINIO_REGION=
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=


# =============================================================================
# 9. STATE STORES (Postgres / SurrealDB / Redis)
# =============================================================================

# DBDriver picks the persistence layer:
#   memory   — in-process for budget + projects (dev only)
#   postgres — Postgres for budget, memory for projects
#   surreal  — SurrealDB for projects, memory for budget
#   hybrid   — Postgres for budget + SurrealDB for projects (production)
IRONFLYER_DB_DRIVER=memory
POSTGRES_URL=postgres://ironflyer:ironflyer@localhost:5432/ironflyer?sslmode=disable
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_NS=ironflyer
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# Memory / audit ring backends.
IRONFLYER_MEMORY_BACKEND=memory    # memory | surreal | pgvector
IRONFLYER_AUDIT_BACKEND=memory     # memory | surreal

# ---- Redis (cross-pod scaling) ----------------------------------------------
IRONFLYER_REDIS_ENABLED=false
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Redpanda / Kafka event backbone (drains Postgres event_outbox) ---------
REDPANDA_BROKERS=
IRONFLYER_EVENT_PUMP_BATCH=50
IRONFLYER_EVENT_PUMP_INTERVAL=1s
IRONFLYER_EVENT_PUMP_LEASE=30s
IRONFLYER_EVENT_PUMP_MAX_ATTEMPTS=10


# =============================================================================
# 10. DB PROVISIONERS (per-project databases auto-created by the finisher)
# =============================================================================

IRONFLYER_DB_PROVISIONER=none      # none | supabase | shared-postgres

# ---- shared-postgres: carve a per-project DB out of one Postgres ------------
IRONFLYER_SHARED_POSTGRES_ADMIN_DSN=
IRONFLYER_SHARED_POSTGRES_PUBLIC_HOST=
IRONFLYER_SHARED_POSTGRES_PUBLIC_PORT=

# ---- Supabase: Personal Access Token + org id -------------------------------
IRONFLYER_SUPABASE_PAT=
IRONFLYER_SUPABASE_ORG_ID=
IRONFLYER_SUPABASE_REGION=


# =============================================================================
# 11. TRANSACTIONAL EMAIL (optional)
# =============================================================================

IRONFLYER_EMAIL_PROVIDER=none      # resend | sendgrid | none
IRONFLYER_EMAIL_API_KEY=
IRONFLYER_EMAIL_FROM=noreply@ironflyer.dev
IRONFLYER_DASHBOARD_URL=http://localhost:3000


# =============================================================================
# 12. OBSERVABILITY (OpenTelemetry, optional)
# =============================================================================

IRONFLYER_OTEL_EXPORTER=none       # none | stdout | otlp
IRONFLYER_OTEL_ENDPOINT=
IRONFLYER_OTEL_INSECURE=false
IRONFLYER_OTEL_SAMPLE_RATIO=1.0
# Comma-separated `key=value` pairs sent as HTTP headers on every OTLP
# request. Most vendors use this for auth, e.g.:
#   IRONFLYER_OTEL_HEADERS="x-honeycomb-team=YOUR_KEY"
IRONFLYER_OTEL_HEADERS=


# =============================================================================
# 13. SCAFFOLDING
# =============================================================================

IRONFLYER_SCAFFOLD_ROOT=./templates


# =============================================================================
# 14. RUNTIME SERVICE (core/runtime)
# =============================================================================

IRONFLYER_RUNTIME_ADDR=:8090
IRONFLYER_RUNTIME_DRIVER=mock      # mock | docker
IRONFLYER_RUNTIME_WORKSPACE_DIR=./tmp/workspaces
IRONFLYER_RUNTIME_CORS_ORIGIN=http://localhost:3000
# The runtime reuses the orchestrator's JWT secret + preview token secret
# (defined under section 0). Don't redeclare them here.


# =============================================================================
# 15. WEB FRONTEND (clients/web — Next.js)
#
# NEXT_PUBLIC_ vars are inlined into the client bundle at build time. Anything
# secret MUST NOT carry the NEXT_PUBLIC_ prefix.
# =============================================================================

NODE_ENV=development

# Either set the full endpoint URL ...
NEXT_PUBLIC_GRAPHQL_URL=
NEXT_PUBLIC_GRAPHQL_WS_URL=
# ... or set the base (we append /graphql).
NEXT_PUBLIC_IRONFLYER_API_URL=http://localhost:8080
NEXT_PUBLIC_IRONFLYER_WS_URL=ws://localhost:8080

# Browser-side runtime URL (file API + preview iframe).
NEXT_PUBLIC_RUNTIME_URL=http://localhost:8090

# Server-side proxies (used by Next.js API routes if any).
ORCHESTRATOR_URL=http://localhost:8080
RUNTIME_URL=http://localhost:8090

# --- Sentry (optional) ----------------------------------------------------
# Per-service DSNs so each surface ships to its own Sentry project. The
# orchestrator + web also fall back to SENTRY_DSN if their specific var
# is unset, which is useful for monorepo deployments using one project.
# Empty values short-circuit init — local boots stay quiet.
SENTRY_DSN=
SENTRY_DSN_ORCHESTRATOR=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_DSN=
RUNTIME_SENTRY_DSN=
SENTRY_TRACES_SAMPLE=0.05
# Source-map upload only — used by withSentryConfig() in clients/web/next.config.mjs at build time.
SENTRY_ORG=
# Source-map upload only — Sentry project slug consumed by the build-time @sentry/nextjs plugin.
SENTRY_PROJECT=
# Source-map upload only — when unset the source-map upload step is skipped and runtime Sentry still works.
SENTRY_AUTH_TOKEN=

# =============================================================================
# 14. GRAPHQL HARDENING (see DEPLOY.md §5)
#
# Depth + complexity caps are ALWAYS-ON; the env vars below let operators tune
# the ceiling against real traffic. APQ locked mode is opt-in — flip it on once
# the client registry under GRAPHQL_APQ_REGISTRY_DIR is stable so production
# can stop accepting ad-hoc query shapes.
# =============================================================================

# Hard cap on per-operation complexity. Rejects with OPERATION_TOO_COMPLEX
# and a WARN log carrying the operation name + measured score.
GRAPHQL_COMPLEXITY_LIMIT=1000

# Hard cap on selection-set depth. Rejects with OPERATION_TOO_DEEP and a
# WARN log carrying the operation name + measured depth.
GRAPHQL_DEPTH_LIMIT=15

# When true, the APQ surface only serves hashes seeded at startup from
# GRAPHQL_APQ_REGISTRY_DIR. Raw queries return PERSISTED_QUERY_REQUIRED;
# unknown hashes return PERSISTED_QUERY_NOT_REGISTERED. Operators bypass.
GRAPHQL_APQ_LOCKED=false

# Directory scanned at startup; every .graphql / .gql file is parsed and
# each named operation is hashed + registered. Leaving this empty falls
# back to the wired-in default (clients/web/src/lib/gql/operations).
GRAPHQL_APQ_REGISTRY_DIR=

# Apollo tracing extension — verbose, flip on while debugging.
GRAPHQL_TRACING=off

# Introspection — set to off once clients are on a generated SDK.
GRAPHQL_INTROSPECTION=on

# In-memory APQ LRU size. Ignored when GRAPHQL_APQ_LOCKED=true.
GRAPHQL_APQ_LRU=1000

# LRU size for parsed query documents (gqlgen QueryCache).
GRAPHQL_QUERY_CACHE_LRU=1000
