# Ironflyer — environment variables (copy to .env / .env.local).
#
# Every variable the orchestrator, runtime, and web read is listed here.
# Leave a key blank to disable the feature it gates — the orchestrator
# logs a warning at boot and continues with the no-op path.
# ---------------------------------------------------------------------

# ============== Orchestrator (apps/orchestrator) =====================

# HTTP bind + environment flavour
IRONFLYER_ADDR=:8080
IRONFLYER_ENV=dev                 # dev | staging | prod
IRONFLYER_LOG_LEVEL=info          # debug | info | warn | error
IRONFLYER_LOG_FORMAT=console      # console | json
IRONFLYER_AUTH_OPTIONAL=false

# Auth
IRONFLYER_JWT_SECRET=dev-secret-change-me
IRONFLYER_JWT_ISSUER=ironflyer

# Provider keys (blank = provider disabled, mock-only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Storage driver: memory | postgres | surreal | hybrid
IRONFLYER_DB_DRIVER=memory
POSTGRES_URL=postgres://ironflyer:ironflyer@localhost:5432/ironflyer?sslmode=disable
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_NS=ironflyer
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# Workspace runtime URL
IRONFLYER_RUNTIME_URL=http://localhost:8090

# Scaffold templates. Baked into the orchestrator image at /app/templates;
# point this at ./templates for local dev.
IRONFLYER_SCAFFOLD_ROOT=./templates

# Temporal worker (production). Empty host = embedded executor, no worker.
IRONFLYER_TEMPORAL_HOST=
IRONFLYER_TEMPORAL_NAMESPACE=default
IRONFLYER_TEMPORAL_TASK_QUEUE=ironflyer-finisher
# Legacy keys still read by the explicit "temporal" executor path:
IRONFLYER_EXECUTOR=embedded        # embedded | temporal
TEMPORAL_ADDR=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ironflyer-finisher

# Transactional email
IRONFLYER_EMAIL_PROVIDER=none      # resend | sendgrid | none
IRONFLYER_EMAIL_API_KEY=
IRONFLYER_EMAIL_FROM=noreply@ironflyer.dev

# Stripe (blank = checkout + webhook disabled)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:3000/app/settings?stripe=success
STRIPE_CANCEL_URL=http://localhost:3000/pricing?stripe=cancel

# GitHub OAuth (blank = /auth/github/* returns 503)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/auth/github/callback
GITHUB_POST_LOGIN_URL=http://localhost:3000/app

# ============== Runtime (apps/runtime) ================================

IRONFLYER_RUNTIME_ADDR=:8090
IRONFLYER_RUNTIME_DRIVER=mock      # mock | docker
IRONFLYER_RUNTIME_WORKSPACE_DIR=./tmp/workspaces
IRONFLYER_RUNTIME_CORS_ORIGIN=http://localhost:3000
# Reuses the orchestrator JWT secret so signed tokens verify.
# (IRONFLYER_JWT_SECRET above is shared.)

# ============== Web (apps/web) ========================================

NODE_ENV=development
ORCHESTRATOR_URL=http://localhost:8080
RUNTIME_URL=http://localhost:8090
