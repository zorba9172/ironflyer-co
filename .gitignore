# Node / Next.js
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts
!clients/web/next-env.d.ts

# Compiled SDK / package build outputs
packages/*/dist/

# Test artifacts
clients/web/test-results/
clients/web/screenshots/
clients/web/tmp-screenshots/
playwright-report/
coverage/

# Build artifacts inside template starters — NEVER commit. The starters
# themselves (sources, manifests, fastlane config) ARE tracked at
# templates/starters/* per CLAUDE.md ("Real, runnable starters").
templates/*/node_modules/
templates/*/build/
templates/*/.gradle/
templates/*/.expo/
templates/*/dist/
templates/starters/*/node_modules/
templates/starters/*/build/
templates/starters/*/.gradle/
templates/starters/*/.expo/
templates/starters/*/dist/
templates/starters/*/DerivedData/
templates/starters/*/ios/build/
templates/starters/*/android/build/
templates/starters/*/android/app/build/

# Go
bin/
vendor/
*.exe
*.test
*.out
# Compiled Go service binaries (built next to main.go) — never commit.
core/orchestrator/orchestrator
core/runtime/runtime
core/cli/cli

# Third-party marketing asset packs (PSDs, MP4s, MOGRTs, huge PNGs) —
# kept locally for design reference but not tracked.
assets/market/

# Env / secrets
.env
.env.local
.env.*.local
.ironflyer/ide-sync/

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
