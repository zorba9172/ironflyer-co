{
  "name": "@ironflyer/clients",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:marketing": "pnpm --filter @ironflyer/marketing dev",
    "dev:studio": "pnpm --filter @ironflyer/studio dev",
    "dev:backoffice": "pnpm --filter @ironflyer/backoffice dev",
    "dev:mobile": "pnpm --filter @ironflyer/mobile start",
    "build:packages": "pnpm --filter \"./packages/**\" -r build",
    "build:web": "pnpm --filter @ironflyer/marketing --filter @ironflyer/studio --filter @ironflyer/backoffice -r build",
    "typecheck": "pnpm -r --filter \"./clients/**\" --filter \"./packages/**\" exec tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^29.1.1",
    "nx": "^20.3.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "react-router": "^6.28.1",
      "react-router-dom": "^6.28.1"
    }
  }
}
